<?xml version="1.0"?>
<robot name="point_nav_rover">
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.22" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.77 0.62 0.25"/>
      </geometry>
      <material name="blue">
        <color rgba="0.2 0.2 0.9 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.77 0.62 0.25"/>
      </geometry>
    </collision>
  </link>

  <joint name="front_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_left_wheel"/>
    <origin xyz="0.42 0.47 -0.20" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  <link name="front_left_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.1575" length="0.09"/>
      </geometry>
    </visual>
  </link>

  <joint name="front_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_right_wheel"/>
    <origin xyz="0.42 -0.47 -0.20" rpy="1.5708 0 0"/>
    <axis xyz="0 0 -1"/>
  </joint>
  <link name="front_right_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.1575" length="0.09"/>
      </geometry>
    </visual>
  </link>

  <joint name="back_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="back_left_wheel"/>
    <origin xyz="-0.42 0.47 -0.20" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  <link name="back_left_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.1575" length="0.09"/>
      </geometry>
    </visual>
  </link>

  <joint name="back_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="back_right_wheel"/>
    <origin xyz="-0.42 -0.47 -0.20" rpy="1.5708 0 0"/>
    <axis xyz="0 0 -1"/>
  </joint>
  <link name="back_right_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.1575" length="0.09"/>
      </geometry>
    </visual>
  </link>

  <!-- Camera frames for pose/odom sensors -->
  <joint name="zed_front_mount_joint" type="fixed">
    <parent link="base_link"/>
    <child link="zed_front_camera_link"/>
    <!-- From box geometry: x=0.385-0.065479, y=0, z=0.125+0.217128; 30 deg incline -->
    <origin xyz="0.319521 0.0 0.342128" rpy="0 -0.523599 0"/>
  </joint>
  <link name="zed_front_camera_link"/>

  <joint name="zed_rear_mount_joint" type="fixed">
    <parent link="base_link"/>
    <child link="zed_rear_camera_link"/>
    <origin xyz="-0.45 0.00 0.68" rpy="0 0 3.14159"/>
  </joint>
  <link name="zed_rear_camera_link"/>

  <!-- Additional side camera frames -->
  <joint name="zed_left_mount_joint" type="fixed">
    <parent link="base_link"/>
    <child link="zed_left_camera_link"/>
    <origin xyz="0.3095 0.30232 0.21478" rpy="0 -0.523599 1.5708"/>
  </joint>
  <link name="zed_left_camera_link"/>

  <joint name="zed_right_mount_joint" type="fixed">
    <parent link="base_link"/>
    <child link="zed_right_camera_link"/>
    <origin xyz="0.3095 -0.30232 0.21478" rpy="0 -0.523599 -1.5708"/>
  </joint>
  <link name="zed_right_camera_link"/>
</robot>
